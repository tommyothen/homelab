# ---------------------------------------------------------------------------
# Secrets — never commit real env files
# hosts/*/secrets.yaml MUST be encrypted with sops before committing.
# ---------------------------------------------------------------------------
**/.env
*.env

# ---------------------------------------------------------------------------
# NixOS build artifacts
# ---------------------------------------------------------------------------
result
result-*
.direnv/

# ---------------------------------------------------------------------------
# SQLite databases (action gateway audit log — lives on appdata NFS at runtime)
# ---------------------------------------------------------------------------
*.db
*.db-shm
*.db-wal

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# Terraform — secrets and state
# ---------------------------------------------------------------------------
terraform.tfvars
terraform.tfstate
terraform.tfstate.backup
.terraform/
.terraform.lock.hcl

# ---------------------------------------------------------------------------
# Bootstrap build outputs
# ---------------------------------------------------------------------------
bootstrap/oci/result
bootstrap/oci/flake.lock
bootstrap/pi/result
bootstrap/pi/flake.lock

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
